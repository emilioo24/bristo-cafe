---
---

<section class="hero" id="top">
  <div class="hero-bg">
    <!-- Reemplazar con foto real del local -->
    <img
      src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?auto=format&fit=crop&w=1920&q=80"
      alt="Bistro Café Miami — ambiente del local"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <span class="hero-label">Miami · Desde 2011</span>
    <h1 class="hero-title">
      El brunch más<br />
      <em>instagrameable</em><br />
      de Miami.
    </h1>
    <p class="hero-sub">Breakfast & Brunch · Downtown y Coral Gables</p>
    <div class="hero-actions">
      <a href="#carta" class="btn-primary">Ver la carta</a>
      <a
        href="https://www.instagram.com/bistrocaferest"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        Instagram ↗
      </a>
    </div>
  </div>

  <a href="#nosotros" class="hero-scroll" aria-label="Seguir bajando">
    <div class="scroll-line"></div>
  </a>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.06);
    animation: heroZoom 14s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  @keyframes heroZoom {
    to {
      transform: scale(1);
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(18, 6, 0, 0.35) 0%,
      rgba(18, 6, 0, 0.5) 45%,
      rgba(18, 6, 0, 0.78) 100%
    );
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 1.5rem;
    animation: heroFadeUp 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.4s both;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--golden);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(3.2rem, 9vw, 7rem);
    font-weight: 400;
    line-height: 1.03;
    color: #fff;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .hero-title em {
    font-style: italic;
    color: var(--golden);
  }

  .hero-sub {
    font-size: clamp(0.85rem, 2vw, 1rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 3rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--caramel);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.9rem 2.25rem;
    border-radius: 2rem;
    transition:
      background 0.25s,
      transform 0.25s;
  }

  .btn-primary:hover {
    background: var(--golden);
    color: var(--espresso);
    transform: translateY(-2px);
  }

  .btn-secondary {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    padding: 0.9rem 2.25rem;
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.25s;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
    transform: translateY(-2px);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.5));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.4;
      transform: scaleY(0.8);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }
</style>
