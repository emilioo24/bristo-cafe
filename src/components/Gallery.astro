---
// Replace with real photo URLs from @bistrocaferest Instagram
const photos = [
  {
    src: "https://images.unsplash.com/photo-1565299507177-b0ac66763828?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café dish",
  },
  {
    src: "https://images.unsplash.com/photo-1567620905732-2d1ec7ab7445?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café pancakes",
  },
  {
    src: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café gourmet dish",
  },
  {
    src: "https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café brunch",
  },
  {
    src: "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café bowl",
  },
  {
    src: "https://images.unsplash.com/photo-1533089860892-a7c6f0a88666?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café brunch spread",
  },
  {
    src: "https://images.unsplash.com/photo-1490645935967-10de6ba17061?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café breakfast",
  },
  {
    src: "https://images.unsplash.com/photo-1551218808-94e220e084d2?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café eggs",
  },
  {
    src: "https://images.unsplash.com/photo-1504973960431-1c467e159aa4?auto=format&fit=crop&w=700&q=80",
    alt: "Bistro Café food",
  },
];
---

<section class="gallery" id="gallery">
  <div class="gallery-header reveal">
    <span class="label">Gallery</span>
    <h2>As seen on Instagram.</h2>
    <p class="gallery-sub">
      Over 535K followers can't be wrong.
    </p>
  </div>

  <div class="gallery-grid">
    {
      photos.map((photo, i) => (
        <a
          href="https://www.instagram.com/bistrocaferest"
          target="_blank"
          rel="noopener noreferrer"
          class={`gallery-item reveal reveal-delay-${(i % 4) + 1}`}
          aria-label={`View ${photo.alt} on Instagram`}
        >
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          <div class="gallery-overlay">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
            </svg>
          </div>
        </a>
      ))
    }
  </div>

  <div class="gallery-cta reveal">
    <a
      href="https://www.instagram.com/bistrocaferest"
      target="_blank"
      rel="noopener noreferrer"
      class="ig-btn"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <circle cx="12" cy="12" r="4"></circle>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
      </svg>
      Follow @bistrocaferest
    </a>
  </div>
</section>

<style>
  .gallery {
    padding: 9rem 2rem;
    background: var(--latte);
  }

  .gallery-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3.5rem;
  }

  .label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--caramel);
    margin-bottom: 1.25rem;
  }

  .gallery-header h2 {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    color: var(--espresso);
    margin-bottom: 1rem;
  }

  .gallery-sub {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  .gallery-grid {
    max-width: 1200px;
    margin: 0 auto 3.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    display: block;
    background: var(--coffee);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 10, 0, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-cta {
    text-align: center;
  }

  .ig-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--espresso);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    padding: 0.95rem 2.25rem;
    border-radius: 2rem;
    transition:
      background 0.25s,
      transform 0.25s;
  }

  .ig-btn:hover {
    background: var(--coffee);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }
  }

  @media (max-width: 480px) {
    .gallery {
      padding: 6rem 0;
    }

    .gallery-header {
      padding: 0 1.5rem;
    }

    .gallery-cta {
      padding: 0 1.5rem;
    }
  }
</style>
